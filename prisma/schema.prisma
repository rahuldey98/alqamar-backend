generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  email     String?
  password  String
  role      UserRole
  gender    Gender?
  age       Int?
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taughtClasses Class[]        @relation("TeacherClasses")
  enrollments   ClassStudent[] @relation("StudentEnrollments")
}

model Course {
  id             Int     @id @default(autoincrement())
  title          String
  enTitle        String?
  durationMonths Int
  status         Status  @default(ACTIVE)
  classes        Class[]
}

model Class {
  id          Int      @id @default(autoincrement())
  courseId    Int
  course      Course   @relation(fields: [courseId], references: [id])
  teacherId   Int
  teacher     User     @relation("TeacherClasses", fields: [teacherId], references: [id])
  meetLink    String?
  status      Status   @default(ACTIVE)
  startDate   DateTime @default(now())

  schedules ClassSchedule[]
  students  ClassStudent[]
}

model ClassSchedule {
  id        Int       @id @default(autoincrement())
  classId   Int
  class     Class     @relation(fields: [classId], references: [id])
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  status    Status    @default(ACTIVE)
}

model ClassStudent {
  id        Int      @id @default(autoincrement())
  classId   Int
  class     Class    @relation(fields: [classId], references: [id])
  studentId Int
  student   User     @relation("StudentEnrollments", fields: [studentId], references: [id])

  @@unique([classId, studentId])
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum Status {
  ACTIVE
  INACTIVE
}

enum Gender {
  MALE
  FEMALE
}
