generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  email     String?
  password  String
  role      UserRole
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taughtClasses Class[]        @relation("TeacherClasses")
  enrollments   ClassStudent[] @relation("StudentEnrollments")
}

model Class {
  id          Int          @id @default(autoincrement())
  name        String
  subject     ClassSubject
  teacher     User         @relation("TeacherClasses", fields: [teacherId], references: [id])
  teacherId   Int
  meetLink    String?
  description String?
  status      Status       @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  schedules ClassSchedule[]
  students  ClassStudent[]
}

model ClassSchedule {
  id        Int       @id @default(autoincrement())
  class     Class     @relation(fields: [classId], references: [id])
  classId   Int
  dayOfWeek DayOfWeek
  startTime DateTime
  endTime   DateTime
  status    Status    @default(ACTIVE)
}

model ClassStudent {
  id        Int   @id @default(autoincrement())
  classId   Int
  class     Class @relation(fields: [classId], references: [id])
  studentId Int
  user      User? @relation("StudentEnrollments", fields: [userId], references: [id])
  userId    Int?

  @@unique([classId, studentId])
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ClassSubject {
  ARABIC
  URDU
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum Status {
  ACTIVE
  INACTIVE
}
