generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  email     String?
  password  String
  role      UserRole
  gender    Gender?
  age       Int?
  status    Status   @default(ACTIVE)
  // TODO: remove User.meetLink once all clients read from Teacher.meetLink. Kept here as a backward-compatible mirror.
  meetLink  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher     Teacher?
  student     Student?
  attendances Attendance[]
}

model Teacher {
  userId   Int     @id
  user     User    @relation(fields: [userId], references: [id])
  meetLink String?

  taughtClasses Class[] @relation("TeacherClasses")
}

model Student {
  userId   Int       @id
  user     User      @relation(fields: [userId], references: [id])
  feesDate DateTime?
  courseId Int?
  course   Course?   @relation(fields: [courseId], references: [id])
  classId  Int?
  class    Class?    @relation("ClassStudents", fields: [classId], references: [id])
}

model Course {
  id             Int       @id @default(autoincrement())
  title          String
  enTitle        String?
  durationMonths Int
  status         Status    @default(ACTIVE)
  classes        Class[]
  students       Student[]
}

model Class {
  id        Int       @id @default(autoincrement())
  courseId  Int
  course    Course    @relation(fields: [courseId], references: [id])
  teacherId Int
  teacher   Teacher   @relation("TeacherClasses", fields: [teacherId], references: [userId])
  meetLink  String?
  status    Status    @default(ACTIVE)
  startDate DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  schedules   ClassSchedule[]
  students    Student[]       @relation("ClassStudents")
  attendances Attendance[]
}

model ClassSchedule {
  id        Int       @id @default(autoincrement())
  classId   Int
  class     Class     @relation(fields: [classId], references: [id])
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  status    Status    @default(ACTIVE)
}

model Attendance {
  id        Int      @id @default(autoincrement())
  classId   Int
  class     Class    @relation(fields: [classId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  date      String
  createdAt DateTime @default(now())

  @@unique([classId, userId, date])
}

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum Status {
  ACTIVE
  INACTIVE
}

enum Gender {
  MALE
  FEMALE
}
